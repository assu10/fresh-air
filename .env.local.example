# 에어코리아 API
# 발급: https://www.data.go.kr 에서 "한국환경공단_에어코리아_대기오염정보" 검색 후 활용신청
AIRKOREA_API_KEY=

# VAPID 키 (Web Push 인증)
# 생성: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# Upstash Redis
# 생성: https://console.upstash.com → Redis → Create Database
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 크론 보안 시크릿 (임의의 긴 문자열)
# 생성 예: openssl rand -hex 32
# cron-job.org에서 요청 헤더 x-cron-secret 에 동일한 값 설정
CRON_SECRET=
